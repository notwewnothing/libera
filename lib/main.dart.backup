import 'package:flutter/material.dart';
import 'package:flutter/services.dart';
import 'package:webview_flutter/webview_flutter.dart';
import 'package:webview_flutter_android/webview_flutter_android.dart';

void main() {
  WidgetsFlutterBinding.ensureInitialized();

  SystemChrome.setPreferredOrientations([
    DeviceOrientation.portraitUp,
    DeviceOrientation.portraitDown,
    DeviceOrientation.landscapeLeft,
    DeviceOrientation.landscapeRight,
  ]);

  runApp(const MyApp());
}

class MyApp extends StatelessWidget {
  const MyApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'Video Stream App',
      theme: ThemeData(
        colorScheme: ColorScheme.fromSeed(seedColor: Colors.deepPurple),
        useMaterial3: true,
      ),
      home: const MyHomePage(title: 'Dih 🥀'),
    );
  }
}

class MyHomePage extends StatefulWidget {
  const MyHomePage({super.key, required this.title});

  final String title;

  @override
  State<MyHomePage> createState() => _MyHomePageState();
}

class _MyHomePageState extends State<MyHomePage> {
  late final WebViewController _controller;

  final String _videoUrl =
      'https://www.vidking.net/embed/tv/220102/1/8?color=ff0000&autoPlay=true&nextEpisode=true&episodeSelector=true';

  @override
  void initState() {
    super.initState();

    _controller = WebViewController()
      ..setJavaScriptMode(JavaScriptMode.unrestricted)
      ..setBackgroundColor(const Color(0x00000000))
      ..setNavigationDelegate(
        NavigationDelegate(
          onProgress: (int progress) {},
          onPageStarted: (String url) {
            debugPrint("Loading URL: $url");
            if (url.contains('google.com')) {
              debugPrint("Google detected! Redirecting back to video...");
              _controller.loadRequest(Uri.parse(_videoUrl));
            }
          },
          onPageFinished: (String url) {},
          onWebResourceError: (WebResourceError error) {
            debugPrint("WebView Error: ${error.description}");
          },
          // حل المشكلة: فحص ومنع الروابط غير المرغوبة والإعلانات قبل تحميلها
          onNavigationRequest: (NavigationRequest request) {
            final url = request.url;

            // 1. حظر الروابط التي تبدأ بـ intent:// أو أي بروتوكول غير http/https لمنع الخطأ الظاهر في الصورة
            if (!url.startsWith('http://') && !url.startsWith('https://')) {
              debugPrint("Blocked unknown scheme: $url");
              return NavigationDecision.prevent; // منع التحميل تماماً
            }

            // 2. إذا حاول المتصفح الانتقال تلقائياً لموقع إعلانات خارجي (مثل phidlerdail.net الظاهر بالصورة)
            // وكان الرابط لا يخص موقع الفيديو الأصلي أو جوجل، قم بحظره
            if (!url.contains('vidking.net') && !url.contains('google.com')) {
              debugPrint("Blocked third-party ad redirect: $url");
              return NavigationDecision
                  .prevent; // حظر الإعلان وإبقاء المستخدم في صفحة الفيديو
            }

            return NavigationDecision
                .navigate; // السماح بالانتقال إذا كان الرابط آمناً
          },
        ),
      )
      ..loadRequest(Uri.parse(_videoUrl));

    if (_controller.platform is AndroidWebViewController) {
      (_controller.platform as AndroidWebViewController)
          .setMediaPlaybackRequiresUserGesture(false);
    }
  }

  @override
  Widget build(BuildContext context) {
    final isLandscape =
        MediaQuery.of(context).orientation == Orientation.landscape;

    return Scaffold(
      appBar: isLandscape
          ? null
          : AppBar(
              backgroundColor: Theme.of(context).colorScheme.inversePrimary,
              title: Text(widget.title),
            ),
      body: Column(
        children: [
          Expanded(child: WebViewWidget(controller: _controller)),
          if (!isLandscape)
            const Padding(
              padding: EdgeInsets.all(16.0),
              child: Text(
                'Now Playing',
                style: TextStyle(fontWeight: FontWeight.bold),
              ),
            ),
        ],
      ),
    );
  }
}
